.DS_Store
.git/
.github/
__pycache__/
*.py[cod]

*.gguf
*.onnx
*.pt
*.pth
*.safetensors
.cache/
.runtime/

agent_lab/downloads/
agent_lab/logs/*.log
agent_lab/models/
agent_lab/redis/
agent_lab/speaker_id/
agent_lab/workspace/extracted_tmp_archive_*
tests/

# Native macOS app wrapper and release artifacts are not used by Docker images.
macos/

# Verba source now lives in the verba store; exclude local verba files from build context.
verba/*
!verba/__init__.py

# Portal source now lives in the portal store; exclude local portal files from build context.
portals/*
!portals/__init__.py

# Core source now lives in the core store; exclude local core files from build context.
cores/*
!cores/__init__.py
